{
  "name": "ai-hub",
  "version": "1.0.0",
  "description": "A web-based hub for interacting with multiple AI tools like ChatGPT, Claude, and Blackbox AI",
  "main": "server.js",
  "scripts": {
    "start": "node dist/server.js",
    "dev": "nodemon src/server.ts",
    "build": "tsc && shx cp -r public dist/",
    "postinstall": "npm run build",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "google-auth-library": "^10.6.2",
    "jsonwebtoken": "^9.0.2",
    "mongodb-memory-server": "^10.4.3",
    "mongoose": "^8.23.1"
  },
  "devDependencies": {
    "@types/axios": "^0.9.36",
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/mongoose": "^5.11.96",
    "@types/node": "^25.6.0",
    "@types/supertest": "^7.2.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.14",
    "shx": "^0.4.0",
    "superagent": "^8.1.2",
    "supertest": "^6.3.4",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  },
  "keywords": [
    "ai",
    "chatgpt",
    "claude",
    "blackbox",
    "hub"
  ],
  "author": "",
  "license": "ISC",
  "engines": {
    "node": ">=14.0.0"
  }
}
